{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node20",
    "rootDir": "src",
    "outDir": "lib",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "stripInternal": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*.ts", "scenarios/**/*.ts", "docs/**/*.ts", "benchmarks/**/*.ts"]
}
