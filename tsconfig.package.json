{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "stripInternal": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*.ts", "scenarios/**/*.ts", "docs/**/*.ts", "benchmarks/**/*.ts"]
}
