{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShinBucketDeployment Asset Benchmark Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "runToken": {
      "type": "string",
      "minLength": 1
    },
    "snapshotDate": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "outputFile": {
      "type": "string",
      "minLength": 1
    },
    "scratchRoot": {
      "type": "string",
      "minLength": 1
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1
    },
    "destinationPrefix": {
      "type": "string",
      "minLength": 1
    },
    "assetProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["tiny-many", "mixed", "large-few"]
      }
    },
    "implementations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["shin", "aws"]
      }
    },
    "lambdaConfigs": {
      "$ref": "#/$defs/lambdaConfigs"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetState", "name"],
        "properties": {
          "assetState": {
            "enum": ["baseline", "changed", "pruned"]
          },
          "cloudfrontWait": {
            "type": "boolean"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "prune": {
            "type": "boolean"
          },
          "deleteDestinationObjectsOnDelete": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "lambdaConfigs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memoryMb", "parallel"],
        "properties": {
          "memoryMb": {
            "type": "integer",
            "minimum": 1
          },
          "parallel": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
