{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShinBucketDeployment Asset Benchmark Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "methodologyVersion": {
      "enum": [1, 2]
    },
    "runId": {
      "type": "string",
      "format": "uuid",
      "minLength": 1
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1
    },
    "startRepetition": {
      "type": "integer",
      "minimum": 1
    },
    "maxWallClockMinutes": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "preserveOnFailure": {
      "type": "boolean"
    },
    "detailedFailureDiagnostics": {
      "type": "boolean"
    },
    "runToken": {
      "type": "string",
      "minLength": 1
    },
    "snapshotDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "decisionRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "comparisonVariant": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "outputFile": {
      "type": "string",
      "minLength": 1
    },
    "scratchRoot": {
      "type": "string",
      "minLength": 1
    },
    "concurrency": {
      "type": "integer",
      "const": 1
    },
    "destinationPrefix": {
      "type": "string",
      "minLength": 1
    },
    "assetProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["tiny-many", "mixed", "large-few", "marker-heavy", "multi-source-prune"]
      }
    },
    "implementations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["shin", "aws"]
      }
    },
    "lambdaConfigs": {
      "$ref": "#/$defs/lambdaConfigs"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetState", "name"],
        "properties": {
          "assetState": {
            "enum": ["baseline", "changed", "pruned"]
          },
          "cloudfrontWait": {
            "type": "boolean"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "deleteStaleObjects": {
            "type": "boolean"
          },
          "deleteCurrentObjectsOnDelete": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "lambdaConfigs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memoryMb", "parallel"],
        "properties": {
          "memoryMb": {
            "type": "integer",
            "minimum": 1
          },
          "parallel": {
            "type": "integer",
            "minimum": 1
          },
          "sourceWindowBytes": {
            "type": ["integer", "null"],
            "minimum": 1
          }
        }
      }
    }
  }
}
