{
  "$schema": "../schemas/asset-benchmark-config.schema.json",
  "region": "ap-southeast-2",
  "concurrency": 8,
  "assetProfiles": ["tiny-many", "mixed"],
  "implementations": ["shin", "aws"],
  "lambdaConfigs": [
    {
      "memoryMb": 5120,
      "parallel": 256
    },
    {
      "memoryMb": 6144,
      "parallel": 256
    }
  ],
  "phases": [
    {
      "name": "cold-create",
      "assetState": "baseline"
    },
    {
      "name": "unchanged-update",
      "assetState": "baseline",
      "retainOnDelete": true
    },
    {
      "name": "changed-update",
      "assetState": "changed"
    },
    {
      "name": "pruned-update",
      "assetState": "pruned"
    }
  ]
}
