{
  "$schema": "../schemas/asset-benchmark-config.schema.json",
  "region": "eu-central-1",
  "concurrency": 1,
  "assetProfiles": ["multi-source-prune"],
  "implementations": ["shin", "aws"],
  "lambdaConfigs": [
    {
      "memoryMb": 1024,
      "parallel": 32
    }
  ],
  "phases": [
    {
      "name": "cold-create",
      "assetState": "baseline"
    },
    {
      "name": "unchanged-update",
      "assetState": "baseline"
    },
    {
      "name": "pruned-update",
      "assetState": "pruned"
    }
  ]
}
