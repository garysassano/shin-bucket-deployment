{
  "$schema": "../schemas/asset-benchmark-config.schema.json",
  "region": "ap-southeast-2",
  "concurrency": 8,
  "assetProfiles": ["tiny-many", "large-few"],
  "implementations": ["shin", "aws"],
  "lambdaConfigs": [
    {
      "memoryMb": 2048,
      "parallel": 32
    },
    {
      "memoryMb": 4096,
      "parallel": 64
    }
  ],
  "phases": [
    {
      "name": "cold-create",
      "assetState": "baseline"
    },
    {
      "name": "unchanged-update",
      "assetState": "baseline",
      "deleteDestinationObjectsOnDelete": false
    },
    {
      "name": "changed-update",
      "assetState": "changed"
    },
    {
      "name": "pruned-update",
      "assetState": "pruned"
    }
  ]
}
