{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"files": {
		"includes": [
			"src/**/*.ts",
			"test/**/*.ts",
			"examples/**/*.ts",
			"package.json",
			"tsconfig.json",
			"vitest.config.ts",
			"README.md"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
