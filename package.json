{
  "name": "shin-bucket-deployment",
  "version": "0.8.0",
  "description": "Rust-backed near drop-in alternative to the AWS CDK BucketDeployment construct",
  "license": "MIT",
  "keywords": [
    "aws",
    "cdk",
    "aws-cdk",
    "s3",
    "bucket-deployment",
    "rust",
    "lambda",
    "static-site"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garysassano/shin-bucket-deployment.git"
  },
  "homepage": "https://github.com/garysassano/shin-bucket-deployment#readme",
  "bugs": {
    "url": "https://github.com/garysassano/shin-bucket-deployment/issues"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib/**/*.js",
    "lib/cataloged-source.d.ts",
    "lib/errors.d.ts",
    "lib/index.d.ts",
    "lib/shin-bucket-deployment.d.ts",
    "assets/bootstrap-arm64/bootstrap.zip",
    "assets/bootstrap-arm64/build-provenance.json",
    "assets/bootstrap-x86_64/bootstrap.zip",
    "assets/bootstrap-x86_64/build-provenance.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:package": "tsc -p tsconfig.package.json",
    "prebuild:bootstrap": "node scripts/build-bootstrap.mjs",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "rust:fmt": "cargo fmt --manifest-path rust/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path rust/Cargo.toml --all --check",
    "rust:check": "cargo check --manifest-path rust/Cargo.toml --all-targets --all-features",
    "rust:clippy": "cargo clippy --manifest-path rust/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path rust/Cargo.toml --all-features",
    "rust:audit": "cargo audit --file rust/Cargo.lock",
    "rust:deny": "cargo deny --manifest-path rust/Cargo.toml --exclude spin@0.10.0 check",
    "test": "vitest run && node --test scripts/*.test.mjs",
    "test:ci": "vitest run --maxWorkers=2 && node --test scripts/*.test.mjs",
    "workflow:lint": "node scripts/actionlint-parallel.mjs",
    "toml:check": "taplo fmt --check mise.toml rust/Cargo.toml rust/deny.toml",
    "npm:audit": "pnpm audit --audit-level high",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:synth": "pnpm verify synth",
    "scenario": "pnpm build && node dist/scenarios/runner.js",
    "verify": "pnpm build && node dist/scenarios/runner.js verify",
    "benchmark": "pnpm build && node dist/scenarios/runner.js benchmark",
    "benchmark:collect": "pnpm build && node dist/benchmarks/src/collect-results.js",
    "benchmark:comparison-report": "pnpm build && node dist/benchmarks/src/render/comparison-report.js",
    "benchmark:publish-results": "pnpm build && node dist/benchmarks/src/publish-results.js",
    "benchmark:telemetry-table": "pnpm build && node dist/benchmarks/src/render/telemetry-table.js",
    "benchmark:run-assets": "pnpm build && node dist/benchmarks/src/run-assets-comparison.js",
    "benchmark:synth": "pnpm build && node scripts/verify-benchmark-plan.mjs && SHIN_BENCH_EXECUTION_ENVIRONMENT_TOKEN=no-aws-synth SHIN_BENCH_INVOCATION_TOKEN=no-aws-synth-invocation node dist/scenarios/runner.js benchmark synth assets --asset-profiles tiny-many --implementations shin,aws --lambda-max-parallel-transfers 32 --lambda-memory-mb 1024 && node scripts/verify-benchmark-synth.mjs",
    "check": "pnpm build && pnpm build:package && pnpm typecheck && pnpm lint && pnpm test && pnpm rust:fmt:check && pnpm rust:clippy && pnpm rust:test && pnpm npm:audit && pnpm rust:audit && pnpm rust:deny && pnpm workflow:lint && pnpm toml:check && pnpm verify:package && pnpm verify:synth && pnpm benchmark:synth",
    "prepack": "pnpm build:package"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.257.0",
    "cargo-lambda-cdk": "^0.0.36",
    "constructs": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "cargo-lambda-cdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.12.4",
    "aws-cdk": "2.1127.0",
    "aws-cdk-lib": "2.260.0",
    "cargo-lambda-cdk": "0.0.36",
    "constructs": "10.6.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "zod": "^4.4.3"
  }
}
