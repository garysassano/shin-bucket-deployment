{
  "name": "cargo-bucket-deployment-prototype",
  "private": true,
  "version": "0.0.0",
  "description": "Local prototype of a Rust-backed CDK bucket deployment construct",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "rust:fmt": "cargo fmt --manifest-path rust/Cargo.toml --all",
    "rust:check": "cargo check --manifest-path rust/Cargo.toml",
    "test": "vitest run",
    "example": "pnpm build && node dist/scripts/example-runner.js"
  },
  "dependencies": {
    "aws-cdk-lib": "2.245.0",
    "cargo-lambda-cdk": "0.0.36",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "24.10.1",
    "aws-cdk": "2.1114.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
