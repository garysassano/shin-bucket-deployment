{
  "name": "shin-bucket-deployment-prototype",
  "private": true,
  "version": "0.0.0",
  "description": "Local prototype of a Rust-backed CDK bucket deployment construct",
  "license": "Apache-2.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "rust:fmt": "cargo fmt --manifest-path rust/Cargo.toml --all",
    "rust:check": "cargo check --manifest-path rust/Cargo.toml",
    "rust:test": "cargo test --manifest-path rust/Cargo.toml",
    "rust:audit": "cargo audit --file rust/Cargo.lock",
    "rust:deny": "cargo deny --manifest-path rust/Cargo.toml check",
    "test": "vitest run",
    "scenario": "pnpm build && node dist/scenarios/runner.js",
    "verify": "pnpm build && node dist/scenarios/runner.js verify",
    "benchmark": "pnpm build && node dist/scenarios/runner.js benchmark",
    "benchmark:collect": "pnpm build && node dist/benchmarks/src/collect-results.js",
    "benchmark:comparison-report": "pnpm build && node dist/benchmarks/src/render/comparison-report.js",
    "benchmark:telemetry-table": "pnpm build && node dist/benchmarks/src/render/telemetry-table.js",
    "benchmark:run-assets": "pnpm build && node dist/benchmarks/src/run-assets-comparison.js"
  },
  "dependencies": {
    "aws-cdk-lib": "2.257.0",
    "cargo-lambda-cdk": "0.0.36",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.12.4",
    "aws-cdk": "2.1124.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "zod": "^4.4.3"
  }
}
